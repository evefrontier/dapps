{
  "name": "@eveworld/assembly",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "ci:build": "tsc && vite build --outDir ../../../build_outputs/smart-assembly-base/dist",
    "lint": "prettier . --check && ESLINT_USE_FLAT_CONFIG=true eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "prettier . --write \"**/*.{js,jsx,ts,tsx,css,scss,md}\" && ESLINT_USE_FLAT_CONFIG=true eslint . --fix --report-unused-disable-directives --max-warnings 0",
    "preview": "nx preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@evefrontier/dapp-kit": "workspace:*",
    "@eveworld/ui-components": "workspace:*",
    "@mui/material": "^7.3.9",
    "@mysten/dapp-kit-core": "^1.2.2",
    "@mysten/dapp-kit-react": "^2.0.1",
    "@tanstack/react-query": "^5.96.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-router-dom": "^7.14.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/ui": "^4.1.3",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-import-x": "^4.15.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vite-plugin-babel": "^1.6.0"
  },
  "nx": {
    "includedScripts": [
      "lint",
      "lint:fix",
      "ci:build",
      "deploy:devnet",
      "test:headless"
    ]
  }
}
