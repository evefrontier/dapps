{
  "name": "@eveworld/assembly",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "ci:build": "tsc && vite build --outDir ../../../build_outputs/smart-assembly-base/dist",
    "lint": "prettier . --check && eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "prettier . --write \"**/*.{js,jsx,ts,tsx,css,scss,md}\" && eslint . --fix --report-unused-disable-directives --max-warnings 0",
    "preview": "nx preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@evefrontier/dapp-kit": "workspace:*",
    "@eveworld/ui-components": "workspace:*",
    "@honeycombio/opentelemetry-web": "^1.3.0",
    "@mui/material": "^7.0.0",
    "@mysten/dapp-kit-core": "^1.2.0",
    "@mysten/dapp-kit-react": "^1.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-web": "^0.49.1",
    "@tanstack/react-query": "^5.91.2",
    "@typescript-eslint/eslint-plugin": "7.13.1",
    "@typescript-eslint/parser": "7.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^4.1.2",
    "react-router-dom": "^6.30.3",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.1.0"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.0",
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "7.0.0",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "postcss": "^8.5.8",
    "prettier": "3.3.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-babel": "^1.6.0"
  },
  "nx": {
    "includedScripts": [
      "lint",
      "lint:fix",
      "ci:build",
      "deploy:devnet",
      "test:headless"
    ]
  }
}
