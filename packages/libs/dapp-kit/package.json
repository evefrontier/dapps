{
  "name": "@evefrontier/dapp-kit",
  "version": "0.1.10",
  "description": "React SDK for EVE Frontier dApps on Sui",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./graphql": {
      "types": "./dist/graphql/index.d.ts",
      "import": "./dist/graphql/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "dependencies": {
    "@evefrontier/wallet-core": "^0.0.1-alpha.9",
    "@mysten/dapp-kit-core": "^1.2.2",
    "@mysten/dapp-kit-react": "^2.0.1",
    "@mysten/sui": "^2.14.1",
    "@mysten/wallet-standard": "^0.20.1",
    "@tanstack/react-query": "^5.96.2",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "4.1.3",
    "@vitest/ui": "4.1.3",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.2",
    "vite": "8.0.5",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "4.1.3"
  },
  "peerDependencies": {
    "@wallet-standard/ui": "^1.0.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/fix-esm-extensions.cjs",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "ts:clean": "tsc --build --clean",
    "docs": "typedoc",
    "docs:md": "typedoc --plugin typedoc-plugin-markdown --out docs/markdown",
    "docs:serve": "typedoc && bunx serve docs/api",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:run": "vitest run"
  }
}
