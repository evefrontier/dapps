{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "./index.ts"
  ],
  "entryPointStrategy": "expand",
  "out": "./docs/api",
  "name": "@evefrontier/dapp-kit",
  "readme": "./README.md",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "categoryOrder": [
    "Providers",
    "Hooks - Connection",
    "Hooks - Notification",
    "Hooks - Smart Object",
    "Hooks - Sponsored Transaction",
    "GraphQL Client",
    "GraphQL Queries",
    "GraphQL Types",
    "Types",
    "Utilities - Config",
    "Utilities - Formatting",
    "Utilities - Assembly",
    "Utilities - Mapping",
    "Utilities - Transforms",
    "Utilities - Error helpers",
    "Wallet",
    "Config",
    "Character Helpers",
    "Constants",
    "Errors",
    "*"
  ],
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "sort": [
    "source-order"
  ],
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "inherited": true,
    "external": false
  }
}
